{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 22, "patch": 0 },
    "configurePresets": [
        {
            "name": "dev",
            "displayName": "Development",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "20",
                "MTL5_BUILD_TESTS": "ON",
                "MTL5_BUILD_EXAMPLES": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20",
                "MTL5_BUILD_TESTS": "OFF",
                "MTL5_BUILD_EXAMPLES": "OFF"
            }
        },
        {
            "name": "ci",
            "displayName": "CI",
            "binaryDir": "${sourceDir}/build-ci",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20",
                "MTL5_BUILD_TESTS": "ON",
                "MTL5_BUILD_EXAMPLES": "ON"
            }
        },
        {
            "name": "ci-regression",
            "displayName": "CI + Regression Tests",
            "binaryDir": "${sourceDir}/build-ci-regression",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20",
                "MTL5_BUILD_TESTS": "ON",
                "MTL5_BUILD_EXAMPLES": "OFF",
                "MTL5_BUILD_REGRESSION_TESTS": "ON"
            }
        }
    ]
}
